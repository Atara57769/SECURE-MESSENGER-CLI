# ==============================================================================
# Secure Messenger - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' or export these environment variables in your shell 
# before starting the messenger server.
# ==============================================================================

# Custom path to the SQLite database file.
# If not specified, defaults to 'messenger.db' in the server's working directory.
MESSENGER_DB_PATH=messenger.db

# A 32-byte (256-bit) hex-encoded encryption key used for server-side AES-256-GCM.
#
# IMPORTANT:
# - If not set, the server will attempt to load a key from '.messenger.key' or 
#   generate a new cryptographically secure key automatically.
# - To manually generate a secure key, run:
#     openssl rand -hex 32
#
MESSENGER_ENCRYPTION_KEY=9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08
